{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Memory Cleaner",
  "version": "0.3.0",
  "identifier": "com.memtool.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Memory Cleaner",
        "width": 980,
        "height": 760,
        "minWidth": 760,
        "minHeight": 580,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns",
      "icons/icon.png"
    ],
    "category": "Utility",
    "copyright": "MIT"
  },
  "plugins": {}
}
